choice = input("Type 'E' for Encrypt or 'D' for Decrypt: ").upper()
key = input("Enter Key: ")

if choice == 'E':
    plaintext = input("Enter Plain Text: ")
    cipher = des_encrypt(plaintext, key)
    print("\nEncrypted Binary:\n", cipher)

elif choice == 'D':
    cipher = input("Enter Cipher Binary: ")
    decrypted = des_decrypt(cipher, key)
    print("\nDecrypted Text:\n", decrypted)

else:
    print("Invalid choice")
